# GitHub Personal Access Token (required)
#
# Used by /api/crawl to search GitHub repos via the Octokit API.
# Without this, the "Search GitHub live" feature will return a 503 error.
#
# How to get one:
#   1. Go to https://github.com/settings/tokens
#   2. Click "Generate new token (classic)"
#   3. Select the "public_repo" scope
#   4. Copy the token and paste it below
#
# Copy this file to .env.local and fill in your token:
#   cp .env.local.sample .env.local

GITHUB_TOKEN=your_github_token_here

